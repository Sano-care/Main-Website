# Sanocare — local environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== CMS =====
CMS_ADMIN_SECRET=long_random_string
CMS_REVALIDATE_SECRET=long_random_string
REVALIDATE_SECRET=long_random_string
NEXT_PUBLIC_CMS_DEV=false

# ===== Homepage feature flags (T61) =====
# Gates the Sanocare Pulse closed-beta TopBanner on the homepage. Hidden by
# default; set to "true" to surface the banner.
NEXT_PUBLIC_SHOW_PULSE_BETA_BANNER=false

# ===== Razorpay (TEST mode) =====
# Get both from https://dashboard.razorpay.com → Settings → API Keys
# The KEY_ID is public (rzp_test_...) — exposed to browser via NEXT_PUBLIC_ prefix.
# The KEY_SECRET is private — server-side only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret_here

# (Optional) Razorpay webhook secret — used to verify webhook signatures.
# Set this in Razorpay dashboard → Webhooks → add webhook → secret.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ===== Ops + lab =====
# Generate with: openssl rand -hex 32
# Used by /api/lab/send-report-payment-link (ops auth header).
OPS_API_TOKEN=long_random_hex
# Public site URL — used to build report magic-links.
NEXT_PUBLIC_SITE_URL=https://sanocare.in

# ===== OTP booking gate (BookingGate) =====
# Server-side secrets — generate fresh with:
#   openssl rand -hex 32     (pepper for hashing the 6-digit code before
#                             storing in otp_verifications.otp_hash)
#   openssl rand -hex 32     (signing key for the verification-token cookie)
OTP_HASH_PEPPER=long_random_hex
OTP_TOKEN_SECRET=long_random_hex

# ===== Dev bypass for OTP =====
# DO NOT enable in production.
# When OTP_DEV_BYPASS=true, /api/auth/send-otp skips the SMS/WhatsApp call
# and logs the plaintext OTP to the server log (Netlify → Functions →
# /api/auth/send-otp). The rest of the flow (rate-limit, hash, insert,
# verify, cookie mint) still runs so the gate UI + booking-insert path
# can be tested end-to-end without spending SMS credits / waiting on DLT.
# Server-only env var — there is no NEXT_PUBLIC mirror, by design.
OTP_DEV_BYPASS=false

# OTP channel routing.
# Current state: Rampwin-primary (WhatsApp via BSP — confirmed working in
# live testing). Meta-direct WhatsApp and MSG91 SMS are both available as
# fallbacks, each gated by its own *_OTP_ENABLED flag.
OTP_DEFAULT_CHANNEL=rampwin
RAMPWIN_OTP_ENABLED=true
WHATSAPP_OTP_ENABLED=false
SMS_OTP_ENABLED=true
# Mirror to the client bundle — BookingGate uses these to pick the primary
# button label and decide whether to show the fallback link. Both rampwin
# and whatsapp render as "WhatsApp" to the patient.
NEXT_PUBLIC_OTP_DEFAULT_CHANNEL=rampwin
NEXT_PUBLIC_RAMPWIN_OTP_ENABLED=true
NEXT_PUBLIC_WHATSAPP_OTP_ENABLED=false
NEXT_PUBLIC_SMS_OTP_ENABLED=true

# MSG91 SMS — primary channel.
# Required once DLT registration clears (typically 1-3 business days):
#   MSG91_AUTH_KEY        — from MSG91 dashboard → API → Auth Key (secret)
#   MSG91_OTP_TEMPLATE_ID — the DLT-approved OTP template ID for the
#                           "Sanocare" sender. The template body must contain
#                           the {{otp}} placeholder; MSG91 substitutes the
#                           6-digit code we generate.
#   MSG91_SENDER_ID       — DLT-registered sender ID ("SANOCR" or similar);
#                           kept for log/audit reference. The sender ID is
#                           bound to the template at DLT level; we do not
#                           pass it per request.
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=

# WhatsApp Cloud API — secondary, disabled until WABA clears.
# Get the Phone Number ID from:
#   developers.facebook.com → Sanocare app → WhatsApp → API Setup →
#   field labelled exactly "Phone number ID" (NOT Business Suite's
#   "Phone profile ID").
WHATSAPP_PHONE_NUMBER_ID=
# Never-expire System User token with whatsapp_business_messaging +
# whatsapp_business_management permissions. See handover doc for how
# to mint this in business.facebook.com → System Users.
WHATSAPP_ACCESS_TOKEN=
# Approved Authentication-category template name. Defaults to "sanocare_otp".
WHATSAPP_OTP_TEMPLATE_NAME=sanocare_otp
WHATSAPP_API_VERSION=v21.0

# ===== Rampwin (WhatsApp via BSP — current primary OTP provider) =====
# POST https://api.rampwin.com/api/messages/send?dontShowInChatList=false
#   headers: { X-API-Key: RAMPWIN_API_KEY, Content-Type: application/json }
#   body:    { channel_id, phone_number (91+10 digits), hide_from_chat, template }
# Response shape: { success: true, data: { messageId: "..." } } — anything
# other than success === true is treated as a delivery failure.
RAMPWIN_API_KEY=
RAMPWIN_CHANNEL_ID=69f4772f10198a2eb3cda6f2
# Optional. Defaults to the documented endpoint URL including the
# dontShowInChatList query param. Override only for staging endpoints.
RAMPWIN_API_URL=https://api.rampwin.com/api/messages/send?dontShowInChatList=false
# Approved AUTHENTICATION-category template name registered with Rampwin.
RAMPWIN_OTP_TEMPLATE_NAME=sanocare_otp
