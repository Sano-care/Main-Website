# Sanocare Main-Website — environment variable template.
# Copy to .env.local for development. Never commit .env.local.

# --- Slice 3 (T66) — Aarogya event notifications ---------------------
# Google Business Profile review link. When the medic-app POSTs
# visit_done, Aarogya appends a polite review nudge to the patient
# message ONLY when this is set. The placeholder is recognized and
# silently dropped so a broken link never reaches a patient.
#
# Real URL (per founder): see Netlify env. The repo placeholder must
# NEVER land in prod.
NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://g.page/r/__PLACEHOLDER__/review
