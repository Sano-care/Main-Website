<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Phase 0 permissions: INTERNET only. Phase 1 adds location for
         attendance clock-in; Phase 3 adds CAMERA + RECORD_AUDIO for the
         Daily.co video surface; Phase 4 adds POST_NOTIFICATIONS (Android
         13+) for FCM push. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Phase 1 C4: attendance clock-in captures device location (optional
         — denial → null lat/lng, route still accepts). COARSE is sufficient
         for ops-level "did the medic clock-in at the patient's home"; FINE
         is requested too to satisfy newer Play targeting requirements. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Phase 1.5: continuous adherence pings during the clocked-in window.
         Foreground service with type=location is the legal basis for
         background location access — we do NOT runtime-request
         ACCESS_BACKGROUND_LOCATION in v0 (low grant rate; service runs while
         the persistent notification is shown). Manifest declaration is kept
         for forward-compat (geofence is v0.1+). POST_NOTIFICATIONS is
         requested at first clock-in on Android 13+. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:name=".MedicApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="false"
        android:theme="@style/Theme.SanocareMedic"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SanocareMedic">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 1.5 — continuous location pings while clocked in. The
             foregroundServiceType="location" attribute satisfies Android
             10+; ServiceCompat.startForeground(..., FOREGROUND_SERVICE_TYPE_LOCATION)
             handles the API 34+ enforcement. -->
        <service
            android:name=".attendance.MedicAttendanceService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

</manifest>
